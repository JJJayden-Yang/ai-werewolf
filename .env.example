# 环境变量样例 —— 复制为 `.env`（已被 gitignore）后填入真实值。
# 红线：不把真实密钥提交到仓库。`.gitlab-ci.yml` 已启用 Secret Detection。

# === LLM ===

# Provider 选择：volcengine_ark | openai_compatible | fake
LLM_PROVIDER=volcengine_ark

# Volcengine Ark / Doubao（模型档位 PRO / CODE）
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_PRO_API_KEY=your_pro_api_key_here
ARK_PRO_ENDPOINT_ID=your_pro_endpoint_id_here
ARK_CODE_API_KEY=your_code_api_key_here
ARK_CODE_ENDPOINT_ID=your_code_endpoint_id_here

# DeepSeek 官方 API（模型档位 DEEPSEEK；start_game/run_v0_batch 用 --model-flavor DEEPSEEK，
# 前端选 "DeepSeek V4 Flash"）。只需 API_KEY；BASE_URL / MODEL 有默认值，按需覆盖。
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI-compatible（可选，按需取消注释）
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=

# === API / Storage ===

# 存储后端：memory（默认，开发/单元测试） | jsonl（本地持久化落盘）
AI_WOLF_STORAGE_BACKEND=memory

# JSONL 后端的数据根目录。实际落盘：
#   <dir>/events/<game_id>.jsonl
#   <dir>/traces/<game_id>.jsonl
AI_WOLF_DATA_DIR=./data

# uvicorn 监听端口（容器内）。host 端映射端口在 docker run 时指定。
AI_WOLF_API_PORT=8000
